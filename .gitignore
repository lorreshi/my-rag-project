*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environment
.venv/
venv/
ENV/

# Environment variables
.env
.env.local

# Secrets in config (keep template, ignore real settings)
config/settings.yaml

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Agent / tooling local files
.github/

# Private content (kept only in the separate private repo: rag_spec)
# These are symlinks into ../my-rag-project-private; no trailing slash so the
# symlinks themselves are ignored (git treats a symlink as a file).
DEV_SPEC.md
.claude
.kiro
tmp_summary_note

# OS
.DS_Store
Thumbs.db

# Project data (runtime generated)
data/db/
data/images/
data/documents/
cache/
logs/

# Byte-compiled
*.pyc

# Local-only test fixtures / generated sample documents (not shipped in repo)
tests/fixtures/sample_documents/
# Local-only golden set tied to a private ingested corpus (not reproducible in repo)
tests/fixtures/golden_rail.json
tests/fixtures/golden_rail_hard.json
# Local-only synonym dict (A/B showed no effect on current corpus; default off)
config/synonyms_rail.json
tests/fixtures/golden_rail_hard.json

